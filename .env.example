# Copy to `.env` at repo root for docker-compose variable substitution (optional).
POSTGRES_USER=ai_copilot
POSTGRES_PASSWORD=ai_copilot_dev
POSTGRES_DB=ai_copilot
POSTGRES_PORT=5432

# --- API (`apps/api`) — copy to `apps/api/.env` or export when running uvicorn ---
# DATABASE_URL=postgresql+psycopg://ai_copilot:ai_copilot_dev@localhost:5432/ai_copilot
# APP_ENV=development
# STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=.local-storage/objects
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=
# AWS_ENDPOINT_URL=

# --- Web (`apps/web`) ---
# VITE_API_BASE_URL=http://localhost:8000
