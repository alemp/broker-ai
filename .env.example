# Optional: copy to `.env` at repo root for docker compose variable substitution.

# Postgres
POSTGRES_USER=ai_copilot
POSTGRES_PASSWORD=ai_copilot_dev
POSTGRES_DB=ai_copilot
POSTGRES_PORT=5432

# Published ports (host)
API_PORT=8000
WEB_PORT=8080

# API (used by `api` service in docker-compose)
# DATABASE_URL is set inside compose to reach the `postgres` service.
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24
APP_ENV=development
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DEFAULT_ORGANIZATION_SLUG=default

# Web build arg: URL the browser uses to call the API (rebuild web after changes)
VITE_API_BASE_URL=http://localhost:8000

# --- API on host (`apps/api`) — copy to `apps/api/.env` or export ---
# DATABASE_URL=postgresql+psycopg://ai_copilot:ai_copilot_dev@localhost:5432/ai_copilot
# STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=.local-storage/objects
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=
# AWS_ENDPOINT_URL=

# --- Web on host (`apps/web/.env`) ---
# VITE_API_BASE_URL=http://localhost:8000
